# EasySlip API Key — สมัครได้ที่ https://developer.easyslip.com
EASYSLIP_API_KEY=your_easyslip_api_key

# Google Apps Script Web App URL
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# บัญชีธนาคารผู้รับเงิน (เลขบัญชีเต็ม ไม่ต้องมีขีด)
RECEIVER_ACCOUNT=1234567890

# อีเมลเจ้าของคอร์สที่จะรับแจ้งเตือนเมื่อมีคนสมัคร
OWNER_EMAIL=your@email.com

# Gmail ที่ใช้ส่งเมลยืนยัน
GMAIL_USER=your@gmail.com

# Gmail App Password (ไม่ใช่รหัส Gmail ปกติ)
# วิธีสร้าง: myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=your_16_char_app_password
